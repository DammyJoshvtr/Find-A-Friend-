                             "backgroundColor":  "#0d0d14",
                             "name":  "FAF",
                             "shortName":  "FAF",
                             "description":  "Your campus social app",
                             "display":  "standalone",
                             "orientation":  "portrait",
                             "scope":  "/",
                             "startUrl":  "/"
                         },
                 "plugins":  [
                                 "expo-router",
                                 "expo-secure-store",
                                 "expo-image-picker",
                                 [
                                     "expo-font",
                                     {
                                         "fonts":  [
                                                       "node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Ionicons.ttf"
                                                   ]
                                     }
                                 ],
                                 [
                                     "expo-notifications",
                                     {
                                         "icon":  "./assets/images/icon.png",
                                         "color":  "#a78bfa",
                                         "defaultChannel":  "default"
                                     }
                                 ],
                                 [
                                     "expo-video",
